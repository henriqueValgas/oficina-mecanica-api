create database oficinamecanicadb;

CREATE TABLE pessoa (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    email VARCHAR(150),
    ativo BOOLEAN NOT NULL DEFAULT TRUE,

    created_date TIMESTAMP NOT NULL,
    updated_date TIMESTAMP,

    endereco_id BIGINT UNIQUE,

    CONSTRAINT fk_pessoa_endereco
        FOREIGN KEY (endereco_id)
        REFERENCES endereco(id)
);

CREATE TABLE pessoa_fisica (
	id BIGINT PRIMARY KEY,

    nome VARCHAR(150) NOT NULL,
    cpf VARCHAR(14) NOT NULL UNIQUE,

    CONSTRAINT fk_pessoa_fisica_pessoa
		FOREIGN KEY (id)
        REFERENCES pessoa(id)
);

CREATE TABLE pessoa_juridica (
	id BIGINT PRIMARY KEY,

    razao_social VARCHAR(150) NOT NULL,
    nome_fantasia VARCHAR(150) NOT NULL,
    cnpj VARCHAR(18) NOT NULL UNIQUE,
    observacao VARCHAR(1000),

    CONSTRAINT fk_pessoa_juridica_pessoa
		FOREIGN KEY (id)
        REFERENCES pessoa(id)
);

CREATE TABLE endereco (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    rua VARCHAR(150),
    numero VARCHAR(20),
    bairro VARCHAR(50),
    cidade VARCHAR(100),
    estado VARCHAR(50),
    cep VARCHAR(20),

    created_date TIMESTAMP,
    updated_date TIMESTAMP
);

CREATE TABLE telefone (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    numero VARCHAR(20) NOT NULL,
    tipo VARCHAR(30), -- ex: WHATSAPP, FIXO, CELULAR

    pessoa_id BIGINT NOT NULL,

    created_date TIMESTAMP,
    updated_date TIMESTAMP,

    CONSTRAINT fk_telefone_pessoa
        FOREIGN KEY (pessoa_id)
        REFERENCES pessoa(id)
);

CREATE TABLE fornecedor (

	id BIGINT PRIMARY KEY AUTO_INCREMENT,

    cnpj VARCHAR(18) UNIQUE NOT NULL,
    razao_social VARCHAR(150) NOT NULL,
    nome_fantasia VARCHAR(150) NOT NULL,

    ativo BOOLEAN NOT NULL DEFAULT TRUE,

    created_date TIMESTAMP,
    updated_date TIMESTAMP
);

CREATE TABLE fabricante (
	id BIGINT PRIMARY KEY NOT NULL,

    nome VARCHAR(150),
    pais_origem VARCHAR(100),

    ativo BOOLEAN NOT NULL DEFAULT TRUE,

    created_date TIMESTAMP,
    updated_date TIMESTAMP
);

CREATE TABLE peca (

	id BIGINT PRIMARY KEY NOT NULL,

	nome VARCHAR(150) NOT NULL,
    codigo VARCHAR(150) NOT NULL,
    descricao VARCHAR(150) NOT NULL,
    categoria VARCHAR(150) NOT NULL,
    valor DOUBLE(10,2) NOT NULL,

    fabricante_id BIGINT,

    ativo BOOLEAN NOT NULL DEFAULT TRUE,

    created_date TIMESTAMP,
    updated_date TIMESTAMP

    CONSTRAINT fk_peca_fabricante
    FOREIGN KEY (fabricante_id)
    REFERENCES fabricante(id)
);